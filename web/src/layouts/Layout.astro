---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "YVid — Sleek video & audio downloader",
  description = "Download videos and audio from anywhere with YVid's beautiful GUI and powerful CLI. Fast, free, and open-source.",
  ogImage = "/og-image.png",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/webp" href="/logo-48x48.webp" sizes="48x48" />
    <link rel="apple-touch-icon" href="/logo-256x256.webp" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://yvid.pages.dev" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts preconnect + stylesheet -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-yvid-950 overflow-x-hidden">
    <slot />
  </body>
</html>
