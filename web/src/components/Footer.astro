---
// Footer component
---

<footer class="relative border-t border-white/[0.06]">
  <!-- Subtle top glow -->
  <div
    aria-hidden="true"
    class="absolute -top-px left-1/2 -translate-x-1/2 w-[300px] h-px bg-gradient-to-r from-transparent via-white/[0.12] to-transparent"
  ></div>

  <div class="section-container py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 group mb-4 w-fit">
          <img
            src="/logo-48x48.webp"
            alt="YVid logo"
            width="28"
            height="28"
            class="rounded-md transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
          <span class="font-semibold text-white">YVid</span>
        </a>
        <p class="text-sm text-white/40 max-w-sm leading-relaxed">
          Sleek video & audio downloader. Beautiful GUI meets
          powerful CLI. 100% free and open-source.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <span class="text-xs font-semibold text-white/50 uppercase tracking-widest mb-3 block"
          >Product</span
        >
        <ul class="space-y-2">
          <li>
            <a
              href="#install"
              class="text-sm text-white/40 hover:text-white transition-colors duration-200"
              >Install</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-sm text-white/40 hover:text-white transition-colors duration-200"
              >Documentation</a
            >
          </li>
          <li>
            <a
              href="#architecture"
              class="text-sm text-white/40 hover:text-white transition-colors duration-200"
              >Architecture</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-sm text-white/40 hover:text-white transition-colors duration-200"
              >Release Notes</a
            >
          </li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <span
          class="text-xs font-semibold text-white/50 uppercase tracking-widest mb-3 block"
          >Community</span
        >
        <ul class="space-y-2">
          <li>
            <a
              href="https://github.com/zaidejjo/yvid"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-white/40 hover:text-white transition-colors duration-200 flex items-center gap-1.5"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
                />
              </svg>
              GitHub
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-sm text-white/40 hover:text-white transition-colors duration-200"
              >Discussions</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-sm text-white/40 hover:text-white transition-colors duration-200"
              >Report Issue</a
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-10 pt-6 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <span class="text-xs text-white/30"
        >&copy; {new Date().getFullYear()} YVid. MIT License.</span
      >
      <div class="flex items-center gap-4">
        <a
          href="#"
          class="text-xs text-white/30 hover:text-white/50 transition-colors"
          >Privacy</a
        >
        <a
          href="#"
          class="text-xs text-white/30 hover:text-white/50 transition-colors"
          >Terms</a
        >
        <a
          href="#"
          class="text-xs text-white/30 hover:text-white/50 transition-colors"
          >License</a
        >
      </div>
    </div>
  </div>
</footer>
