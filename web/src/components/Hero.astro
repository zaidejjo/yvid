---
// Hero Section — macOS-inspired glassmorphic dark theme
---

<section
  id="hero"
  class="relative min-h-[calc(100vh-5rem)] flex items-center overflow-hidden"
>
  <!-- Background Ambient Glows -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
    <!-- Primary blue glow (top-left) -->
    <div
      class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full opacity-20 animate-glow-pulse"
      style="
        background: radial-gradient(circle, rgba(59,130,246,0.4) 0%, transparent 70%);
      "
    ></div>
    <!-- Cyan glow (top-right) -->
    <div
      class="absolute -top-20 -right-20 w-[500px] h-[500px] rounded-full opacity-15 animate-glow-pulse"
      style="
        background: radial-gradient(circle, rgba(6,182,212,0.3) 0%, transparent 70%);
        animation-delay: 1.5s;
      "
    ></div>
    <!-- Subtle bottom glow -->
    <div
      class="absolute -bottom-40 left-1/2 -translate-x-1/2 w-[800px] h-[400px] rounded-full opacity-10"
      style="
        background: radial-gradient(ellipse, rgba(59,130,246,0.2) 0%, transparent 70%);
      "
    ></div>
  </div>

  <!-- Subtle grid overlay -->
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.015]"
    style="
      background-image:
        linear-gradient(rgba(255,255,255,0.15) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.15) 1px, transparent 1px);
      background-size: 48px 48px;
    "
  ></div>

  <div class="section-container relative z-10 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Text Content -->
      <div class="flex flex-col gap-8 pt-8 lg:pt-0">
        <!-- Badge -->
        <div
          class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-xs font-medium text-white/70 w-fit animate-fade-in"
        >
          <span
            class="w-1.5 h-1.5 rounded-full bg-green-400 shadow-[0_0_8px_rgba(74,222,128,0.5)]"
          ></span>
          v2.0.0 — Open Source
        </div>

        <!-- Headline -->
        <h1
          class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] text-balance animate-slide-up"
        >
          Sleek
          <br />
          <span class="gradient-text glow-text">
            video & audio
          </span>
          <br />
          downloader
        </h1>

        <!-- Subtitle -->
        <p
          class="text-lg sm:text-xl text-white/50 max-w-xl leading-relaxed animate-slide-up"
          style="animation-delay: 0.1s"
        >
          Beautiful GUI meets powerful CLI. Download videos, audio, and
          playlists from anywhere with blazing speed and a clean modular
          codebase.
        </p>

        <!-- CTA Buttons -->
        <div
          class="flex flex-wrap gap-4 animate-slide-up"
          style="animation-delay: 0.2s"
        >
          <a href="#install" class="btn-primary text-base !px-8 !py-4 !rounded-2xl glow-blue">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Download GUI
          </a>
          <a href="#install" class="btn-secondary text-base !px-8 !py-4 !rounded-2xl">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5"/>
              <line x1="12" y1="19" x2="20" y2="19"/>
            </svg>
            Use CLI
          </a>
        </div>

        <!-- Trust indicators -->
        <div
          class="flex items-center gap-6 text-white/30 text-xs animate-slide-up"
          style="animation-delay: 0.3s"
        >
          <div class="flex items-center gap-2">
            <span class="flex -space-x-1.5">
              <span class="w-5 h-5 rounded-full bg-gradient-to-br from-purple-400 to-pink-400 border border-yvid-950 inline-block"></span>
              <span class="w-5 h-5 rounded-full bg-gradient-to-br from-blue-400 to-cyan-400 border border-yvid-950 inline-block"></span>
              <span class="w-5 h-5 rounded-full bg-gradient-to-br from-amber-400 to-orange-400 border border-yvid-950 inline-block"></span>
            </span>
            <span class="text-white/40">Trusted by <strong class="text-white/60">2.4k+</strong> devs</span>
          </div>
          <span class="w-px h-4 bg-white/10"></span>
          <span>⚡ 100% Free & Open Source</span>
        </div>
      </div>

      <!-- Right: App Mockup -->
      <div
        class="relative flex items-center justify-center animate-slide-up"
        style="animation-delay: 0.15s"
      >
        <!-- Glow behind mockup -->
        <div
          class="absolute w-[350px] h-[350px] md:w-[450px] md:h-[450px] rounded-full opacity-20 blur-3xl"
          style="
            background: radial-gradient(circle, rgba(59,130,246,0.3) 0%, rgba(6,182,212,0.2) 50%, transparent 70%);
          "
        ></div>

        <!-- Mockup Card -->
        <div
          class="relative w-full max-w-md glass-strong rounded-3xl p-1 overflow-hidden
                 shadow-[0_0_60px_-10px_rgba(59,130,246,0.2)]"
        >
          <!-- macOS Traffic Light Dots -->
          <div class="flex items-center gap-2 px-4 pt-3.5 pb-2">
            <span class="w-3 h-3 rounded-full bg-red-400/80 shadow-[0_0_6px_rgba(248,113,113,0.3)]"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-400/80 shadow-[0_0_6px_rgba(250,204,21,0.3)]"></span>
            <span class="w-3 h-3 rounded-full bg-green-400/80 shadow-[0_0_6px_rgba(74,222,128,0.3)]"></span>
            <span class="ml-3 text-[11px] text-white/30 font-medium font-mono tracking-tight">
              YVid — Download Manager
            </span>
          </div>

          <!-- Mockup Content -->
          <div class="p-4 space-y-3">
            <!-- URL Input Bar -->
            <div class="glass rounded-xl px-4 py-2.5 flex items-center gap-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 shrink-0">
                <circle cx="12" cy="12" r="10"/>
                <path d="M2 12h20"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              <span class="text-sm text-white/40 truncate flex-1">https://www.youtube.com/watch?v=...</span>
              <span class="text-[10px] font-medium text-yvid-400 bg-yvid-500/10 px-2 py-0.5 rounded-md">Paste URL</span>
            </div>

            <!-- Format Selector -->
            <div class="flex gap-2">
              <span class="text-xs font-medium text-white/60 glass rounded-lg px-3 py-1.5">MP4</span>
              <span class="text-xs font-medium text-white/60 glass rounded-lg px-3 py-1.5">MP3</span>
              <span class="text-xs font-medium text-white/90 bg-yvid-500/20 border border-yvid-500/30 rounded-lg px-3 py-1.5">WEBM</span>
              <span class="text-xs font-medium text-white/30 glass rounded-lg px-3 py-1.5 opacity-60">+ More</span>
            </div>

            <!-- Download Item -->
            <div class="glass rounded-xl p-3.5 space-y-2">
              <div class="flex items-start gap-3">
                <!-- Thumbnail placeholder -->
                <div class="w-16 h-10 rounded-lg bg-gradient-to-br from-yvid-800 to-cyan-900 shrink-0 flex items-center justify-center">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/40">
                    <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/>
                    <line x1="8" y1="2" x2="8" y2="22"/>
                    <line x1="16" y1="2" x2="16" y2="22"/>
                    <line x1="2" y1="8" x2="22" y2="8"/>
                    <line x1="2" y1="16" x2="22" y2="16"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-white/80 truncate">Video Title Here</p>
                  <p class="text-xs text-white/40">1080p · WEBM · 234 MB</p>
                </div>
                <span class="text-xs font-mono text-cyan-400 shrink-0 mt-1">85%</span>
              </div>
              <!-- Progress bar -->
              <div class="w-full h-1.5 rounded-full bg-white/5 overflow-hidden">
                <div
                  class="h-full rounded-full bg-gradient-to-r from-yvid-500 to-cyan-500 transition-all duration-500"
                  style="width: 85%"
                ></div>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[11px] text-white/30">⬇ 12.4 MB/s</span>
                <span class="text-[11px] text-white/30">~3s remaining</span>
              </div>
            </div>

            <!-- Queue items -->
            <div class="space-y-1.5">
              <div class="flex items-center gap-3 py-1.5 px-2">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400 shadow-[0_0_6px_rgba(74,222,128,0.5)]"></span>
                <span class="text-xs text-white/50 truncate flex-1">Another video.mp4</span>
                <span class="text-[11px] text-green-400/60">Complete</span>
              </div>
              <div class="flex items-center gap-3 py-1.5 px-2">
                <span class="w-1.5 h-1.5 rounded-full bg-yellow-400/60"></span>
                <span class="text-xs text-white/40 truncate flex-1">Playlist item 03.mp3</span>
                <span class="text-[11px] text-yellow-400/60">Queued</span>
              </div>
            </div>
          </div>

          <!-- Bottom gradient edge -->
          <div class="h-px bg-gradient-to-r from-transparent via-white/[0.06] to-transparent"></div>
        </div>
      </div>
    </div>
  </div>
</section>
