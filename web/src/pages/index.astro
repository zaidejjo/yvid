---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import InstallScript from "../components/InstallScript.astro";
import InstallTabs from "../components/InstallTabs.astro";
import Architecture from "../components/Architecture.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="YVid — Sleek video & audio downloader">
  <Header />
  <main>
    <Hero />
    <InstallScript />
    <InstallTabs />
    <Architecture />

    <!-- Final CTA Section -->
    <section class="section-padding !pt-0 relative">
      <div class="section-container">
        <div
          class="relative max-w-4xl mx-auto glass-strong rounded-3xl p-8 md:p-12 lg:p-16 overflow-hidden
                 text-center shadow-[0_0_60px_-10px_rgba(59,130,246,0.15)]"
        >
          <!-- Inner glow -->
          <div
            aria-hidden="true"
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] opacity-10 pointer-events-none"
            style="
              background: radial-gradient(circle, rgba(59,130,246,0.5) 0%, transparent 70%);
            "
          ></div>

          <div class="relative z-10">
            <span
              class="inline-flex items-center gap-2 px-3 py-1 rounded-full glass text-xs font-medium text-yvid-300 mb-6"
            >
              <span
                class="w-1.5 h-1.5 rounded-full bg-green-400 shadow-[0_0_8px_rgba(74,222,128,0.5)]"
              ></span>
              v2.0.0 — Ready to download
            </span>

            <h2
              class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-balance mb-4"
            >
              Ready to <span class="gradient-text">download anything</span>?
            </h2>
            <p class="text-lg text-white/50 max-w-md mx-auto mb-8">
              Join thousands of users who already use YVid daily. No ads, no
              limits, no nonsense.
            </p>

            <div class="flex flex-wrap justify-center gap-4">
              <a href="#install" class="btn-primary text-base !px-8 !py-4 !rounded-2xl glow-blue">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Get Started Now
              </a>
              <a
                href="https://github.com/zaidejjo/yvid"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary text-base !px-8 !py-4 !rounded-2xl"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                View on GitHub
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
