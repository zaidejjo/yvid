---
// No props needed
---

<header class="fixed top-0 left-0 right-0 z-50">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="glass mt-4 rounded-2xl px-5 py-3 flex items-center justify-between transition-all duration-300"
    >
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <img
          src="/logo-48x48.webp"
          alt="YVid logo"
          width="32"
          height="32"
          class="rounded-lg transition-transform duration-300 group-hover:scale-105"
          loading="eager"
        />
        <span class="font-semibold text-lg text-white tracking-tight"
          >YVid</span
        >
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <a
          href="#install"
          class="text-sm text-white/60 hover:text-white transition-colors duration-200"
        >
          Install
        </a>
        <a
          href="#docs"
          class="text-sm text-white/60 hover:text-white transition-colors duration-200"
        >
          Docs
        </a>
        <a
          href="#architecture"
          class="text-sm text-white/60 hover:text-white transition-colors duration-200"
        >
          Architecture
        </a>
        <a
          href="https://github.com/zaidejjo/yvid"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-white/60 hover:text-white transition-colors duration-200 flex items-center gap-1.5"
        >
          <svg
            width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
          >
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
            />
          </svg>
          GitHub
        </a>
      </div>

      <!-- CTA -->
      <a href="#install" class="btn-primary text-xs !px-4 !py-2 !rounded-xl hidden sm:flex">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download
      </a>
    </div>
  </nav>
</header>
<!-- Spacer for fixed header -->
<div class="h-20"></div>
