---
// Project Architecture / Refactoring Showcase
---

<section id="architecture" class="section-padding relative overflow-hidden">
  <!-- Background ambient -->
  <div
    aria-hidden="true"
    class="absolute top-0 right-0 w-[500px] h-[500px] opacity-[0.06] pointer-events-none"
    style="
      background: radial-gradient(circle, rgba(6,182,212,0.3) 0%, transparent 70%);
    "
  ></div>

  <div class="section-container relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full glass text-xs font-medium text-cyan-300 mb-6"
      >
        <svg
          width="12" height="12" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="16 18 22 12 16 6"/>
          <polyline points="8 6 2 12 8 18"/>
        </svg>
        Clean Architecture
      </span>
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-balance"
      >
        Built with <span class="gradient-text">modular precision</span>
      </h2>
      <p class="mt-4 text-lg text-white/50 max-w-lg mx-auto">
        A cleanly separated codebase where every package has a single
        responsibility. Designed for performance and maintainability.
      </p>
    </div>

    <!-- Architecture Bento Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
      <!-- Card 1: Core Package -->
      <div
        class="glass rounded-2xl p-6 hover:bg-white/[0.06] transition-all duration-300
               group hover:shadow-[0_0_30px_-5px_rgba(59,130,246,0.1)]
               lg:col-span-1"
      >
        <div
          class="w-11 h-11 rounded-xl bg-gradient-to-br from-yvid-500/20 to-yvid-600/10 border border-yvid-500/20
                 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform duration-300"
        >
          <svg
            width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
            stroke-linejoin="round" class="text-yvid-400"
          >
            <box x="3" y="3" width="18" height="18" rx="2"/>
            <line x1="3" y1="9" x2="21" y2="9"/>
            <line x1="9" y1="21" x2="9" y2="9"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">
          <span class="text-yvid-400 font-mono text-sm">core/</span> Package
        </h3>
        <p class="text-sm text-white/50 leading-relaxed mb-3">
          The heart of YVid — cleanly split download logic, format
          negotiation, and playlist parsing into isolated modules with
          zero circular dependencies.
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span
            class="text-[11px] px-2 py-0.5 rounded-md bg-white/[0.04] text-white/40 font-mono"
          >downloader.py</span>
          <span
            class="text-[11px] px-2 py-0.5 rounded-md bg-white/[0.04] text-white/40 font-mono"
          >formats.py</span>
          <span
            class="text-[11px] px-2 py-0.5 rounded-md bg-white/[0.04] text-white/40 font-mono"
          >playlist.py</span>
        </div>
      </div>

      <!-- Card 2: Memory Usage -->
      <div
        class="glass rounded-2xl p-6 hover:bg-white/[0.06] transition-all duration-300
               group hover:shadow-[0_0_30px_-5px_rgba(59,130,246,0.1)]
               lg:col-span-1"
      >
        <div
          class="w-11 h-11 rounded-xl bg-gradient-to-br from-cyan-500/20 to-cyan-600/10 border border-cyan-500/20
                 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform duration-300"
        >
          <svg
            width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
            stroke-linejoin="round" class="text-cyan-400"
          >
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">
          ⚡ Low Memory Footprint
        </h3>
        <p class="text-sm text-white/50 leading-relaxed mb-3">
          Streams content in configurable chunk sizes. No loading entire
          files into RAM — keeps memory usage under 50MB even for 4K
          downloads.
        </p>
        <div class="flex items-center gap-2 text-xs">
          <span
            class="h-1.5 w-24 rounded-full bg-white/5 overflow-hidden inline-block"
          >
            <span
              class="h-full w-3/5 rounded-full bg-gradient-to-r from-green-400 to-cyan-400 block"
            ></span>
          </span>
          <span class="text-green-400/70 font-mono">~42 MB</span>
        </div>
      </div>

      <!-- Card 3: Download Thread -->
      <div
        class="glass rounded-2xl p-6 hover:bg-white/[0.06] transition-all duration-300
               group hover:shadow-[0_0_30px_-5px_rgba(59,130,246,0.1)]
               lg:col-span-1"
      >
        <div
          class="w-11 h-11 rounded-xl bg-gradient-to-br from-purple-500/20 to-purple-600/10 border border-purple-500/20
                 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform duration-300"
        >
          <svg
            width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
            stroke-linejoin="round" class="text-purple-400"
          >
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">
          <span class="text-purple-400 font-mono text-sm">thread/</span> Manager
        </h3>
        <p class="text-sm text-white/50 leading-relaxed mb-3">
          Concurrent download engine with smart queue management. Pause,
          resume, cancel individual items without blocking the UI or CLI.
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span
            class="text-[11px] px-2 py-0.5 rounded-md bg-white/[0.04] text-white/40 font-mono"
          >worker.py</span>
          <span
            class="text-[11px] px-2 py-0.5 rounded-md bg-white/[0.04] text-white/40 font-mono"
          >scheduler.py</span>
        </div>
      </div>

      <!-- Card 4: CLI (spans 2 cols on lg) -->
      <div
        class="glass rounded-2xl p-6 hover:bg-white/[0.06] transition-all duration-300
               group hover:shadow-[0_0_30px_-5px_rgba(59,130,246,0.1)]
               lg:col-span-2"
      >
        <div class="flex items-start gap-4">
          <div
            class="w-11 h-11 rounded-xl bg-gradient-to-br from-emerald-500/20 to-emerald-600/10 border border-emerald-500/20
                   flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300"
          >
            <svg
              width="20" height="20" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
              stroke-linejoin="round" class="text-emerald-400"
            >
              <polyline points="4 17 10 11 4 5"/>
              <line x1="12" y1="19" x2="20" y2="19"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold text-white mb-2">
              <span class="text-emerald-400 font-mono text-sm">cli/</span> Rich Terminal Interface
            </h3>
            <p class="text-sm text-white/50 leading-relaxed mb-4">
              Built with <code class="text-emerald-400/80">rich</code> and
              <code class="text-emerald-400/80">click</code> — beautiful
              progress bars, live download tables, and intuitive command
              structure. Pipe-friendly for scripting.
            </p>
            <div
              class="glass rounded-xl px-4 py-3 font-mono text-xs flex flex-wrap gap-x-6 gap-y-2"
            >
              <span class="text-white/40"
                ><span class="text-emerald-400/70">$</span> yvid dl
                &lt;url&gt; <span class="text-white/20"># Download</span></span
              >
              <span class="text-white/40"
                ><span class="text-emerald-400/70">$</span> yvid list
                <span class="text-white/20"># Show queue</span></span
              >
              <span class="text-white/40"
                ><span class="text-emerald-400/70">$</span> yvid --gui
                <span class="text-white/20"># Launch GUI</span></span
              >
            </div>
          </div>
        </div>
      </div>

      <!-- Card 5: Cross-platform GUI -->
      <div
        class="glass rounded-2xl p-6 hover:bg-white/[0.06] transition-all duration-300
               group hover:shadow-[0_0_30px_-5px_rgba(59,130,246,0.1)]
               lg:col-span-1"
      >
        <div
          class="w-11 h-11 rounded-xl bg-gradient-to-br from-rose-500/20 to-rose-600/10 border border-rose-500/20
                 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform duration-300"
        >
          <svg
            width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
            stroke-linejoin="round" class="text-rose-400"
          >
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Native GUI</h3>
        <p class="text-sm text-white/50 leading-relaxed mb-3">
          A sleek desktop interface built with Dear PyGui — real-time
          download progress, drag-and-drop URL import, and system tray
          integration.
        </p>
        <div class="flex -space-x-1.5">
          <span
            class="text-[11px] px-2 py-0.5 rounded-md bg-white/[0.04] text-white/40"
          >🎨 Dear PyGui</span>
          <span
            class="text-[11px] px-2 py-0.5 rounded-md bg-white/[0.04] text-white/40"
          >📦 PyInstaller</span>
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <div
      class="max-w-3xl mx-auto mt-12 grid grid-cols-2 md:grid-cols-4 gap-px rounded-2xl overflow-hidden glass"
    >
      <div class="p-5 text-center bg-yvid-900/50">
        <span class="text-2xl font-bold gradient-text">12</span>
        <span class="text-xs text-white/40 block mt-1">Core Modules</span>
      </div>
      <div class="p-5 text-center bg-yvid-900/50">
        <span class="text-2xl font-bold gradient-text">98%</span>
        <span class="text-xs text-white/40 block mt-1">Test Coverage</span>
      </div>
      <div class="p-5 text-center bg-yvid-900/50">
        <span class="text-2xl font-bold gradient-text">&lt;50</span>
        <span class="text-xs text-white/40 block mt-1">MB RAM Usage</span>
      </div>
      <div class="p-5 text-center bg-yvid-900/50">
        <span class="text-2xl font-bold gradient-text">3</span>
        <span class="text-xs text-white/40 block mt-1">Platforms</span>
      </div>
    </div>
  </div>
</section>
